---
permalink: /assets/protected.json
# Build-time manifest of password-protected posts, consumed by the
# "Encrypt protected posts" step in the GitHub Actions workflow, which then
# deletes this file before deploy. For each post with `protected: true` it
# lists the site-relative URL, the title and the banner image, so the workflow
# can build a per-post StatiCrypt password page.
---
[{% assign prot = site.posts | where_exp: 'post', 'post.protected' %}{% for post in prot %}{"url":{{ post.url | jsonify }},"title":{{ post.title | jsonify }},"image":{{ post.image.path | default: post.image | default: '' | jsonify }}}{% unless forloop.last %},{% endunless %}{% endfor %}]
