---
layout: compress
swcache: true
# Overrides the Chirpy theme's search index to EXCLUDE password-protected
# posts (front-matter `protected: true`). Otherwise the full post text would
# leak through the site search even though the page itself is encrypted.
---

{% assign searchable = site.posts | where_exp: 'post', 'post.protected != true' %}
[
  {% for post in searchable %}
  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "categories": {{ post.categories | join: ', ' | jsonify }},
    "tags": {{ post.tags | join: ', ' | jsonify }},
    "date": {{ post.date | jsonify }},
    {% capture content -%}{% include post-summary.html full_text=true %}{%- endcapture -%}
    "content": {{ content | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
